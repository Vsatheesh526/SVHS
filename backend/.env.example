# ===== DEVELOPMENT (.env for local) =====
# Copy this file to .env and fill in your local values

# ---- MySQL connection ----
# Local: use localhost, docker container name, or IP
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=school_db

# ---- Auth ----
# Generate a long random string (openssl rand -base64 32)
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Server ----
PORT=5000
# Comma separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# ===== PRODUCTION (.env.production) =====
# For deployment on Render:
# DB_HOST: Get from Railway dashboard (MYSQL_HOST env var)
# DB_PORT: Get from Railway dashboard (MYSQL_PORT env var)
# DB_USER: Get from Railway dashboard (MYSQL_USER env var)
# DB_PASSWORD: Get from Railway dashboard (MYSQL_PASSWORD env var)
# DB_NAME: Get from Railway dashboard (MYSQL_DB env var)
# JWT_SECRET: Generate a new long random string
# PORT: Leave as 5000 (Render assigns the port internally)
# CORS_ORIGIN: Your frontend Vercel URL (e.g., https://mysite.vercel.app)
